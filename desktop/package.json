{
  "name": "chips-gestion-pro",
  "version": "1.0.0",
  "description": "Application de gestion professionnelle pour production de chips",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.chips.gestion-pro",
    "productName": "Chips Gestion Pro",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "../index.html",
      "../style.css",
      "../app.js"
    ],
    "win": {
      "target": ["portable"],
      "icon": null
    },
    "extraResources": [
      { "from": "../", "to": "../", "filter": ["index.html", "style.css", "app.js"] }
    ]
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
