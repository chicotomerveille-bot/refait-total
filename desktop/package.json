{
  "name": "chips-gestion-pro",
  "version": "1.0.0",
  "description": "Application de gestion professionnelle pour production de chips",
  "author": "Chips Gestion Pro",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable",
    "installer": "electron-builder --win nsis",
    "release": "electron-builder --win nsis --publish always"
  },
  "build": {
    "appId": "com.chips.gestion-pro",
    "productName": "Chips Gestion Pro",
    "directories": {
      "output": "_out"
    },
    "files": [
      "main.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "../icon.ico",
      "legalTrademarks": "Chips Gestion Pro"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Chips Gestion Pro",
      "menuCategory": true,
      "displayLanguageSelector": false
    },
    "publish": {
      "provider": "github",
      "owner": "chicotomerveille-bot",
      "repo": "refait-total",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
